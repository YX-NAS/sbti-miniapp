.test-container{background:linear-gradient(180deg,#fff5f8,#f0f8ff);display:flex;flex-direction:column;min-height:100vh}.test-container .loading{align-items:center;display:flex;flex:1;justify-content:center}.test-container .loading .loading-text{color:#ff6b9d;font-size:32rpx;font-weight:600}.test-container .question-scroll{box-sizing:border-box;flex:1;padding:24rpx 20rpx 0}.test-container .question-card{background:#fff;border:2rpx solid rgba(255,107,157,.15);border-radius:32rpx;box-shadow:0 8rpx 24rpx rgba(255,107,157,.08);margin-bottom:20rpx;padding:28rpx 24rpx}.test-container .question-card .question-meta{align-items:center;display:flex;gap:12rpx;margin-bottom:16rpx}.test-container .question-card .question-index{color:#ff6b9d;font-size:26rpx;font-weight:700}.test-container .question-card .supplement-tag{background:#ffe5ec;border:1.5rpx solid rgba(255,107,157,.3);border-radius:999rpx;color:#ff6b9d;font-size:22rpx;font-weight:500;padding:4rpx 16rpx}.test-container .question-card .question-text{color:#3a3a3a;font-size:34rpx;font-weight:500;line-height:1.8;word-break:break-all}.test-container .options-container{display:flex;flex-direction:column;gap:16rpx}.test-container .options-container .option-item{align-items:flex-start;background:#fff;border:2.5rpx solid rgba(77,150,255,.2);border-radius:24rpx;box-shadow:0 4rpx 12rpx rgba(77,150,255,.06);box-sizing:border-box;display:flex;padding:20rpx;transition:all .25s}.test-container .options-container .option-item.selected{background:#eef5ff;border-color:#4d96ff}.test-container .options-container .option-item.selected .option-letter{background:#4d96ff;box-shadow:0 4rpx 12rpx rgba(77,150,255,.3);color:#fff}.test-container .options-container .option-item:active{transform:scale(.98)}.test-container .options-container .option-item .option-letter{align-items:center;background:#e5f3ff;border-radius:50%;color:#4d96ff;display:flex;flex-shrink:0;font-size:28rpx;font-weight:700;height:36rpx;justify-content:center;margin-right:16rpx;margin-top:1rpx;transition:all .25s;width:36rpx}.test-container .options-container .option-item .option-text{color:#3a3a3a;flex:1;font-size:32rpx;line-height:1.7}.test-container .progress-wrapper{background:#fff;border-top:2rpx solid rgba(255,107,157,.1);padding:16rpx 20rpx 10rpx}.test-container .progress-wrapper .progress-bar{background:#ffe5ec;border-radius:3rpx;height:6rpx;margin-bottom:10rpx;overflow:hidden}.test-container .progress-wrapper .progress-fill{background:linear-gradient(90deg,#ff6b9d,#ff8e8e);border-radius:3rpx;height:100%;transition:width .4s}.test-container .progress-wrapper .progress-text{color:#ff6b9d;font-size:24rpx;font-weight:600;text-align:center}.test-container .navigation{background:#fff;border-top:2rpx solid rgba(255,107,157,.1);display:flex;gap:16rpx;padding:16rpx 20rpx calc(16rpx + env(safe-area-inset-bottom))}.test-container .navigation .nav-btn{border:none;border-radius:48rpx;flex:1;font-size:34rpx;font-weight:700;height:96rpx;line-height:96rpx;transition:all .2s}.test-container .navigation .nav-btn::after{border:none}.test-container .navigation .nav-btn.prev-btn{background:#ffe5ec;color:#ff6b9d}.test-container .navigation .nav-btn.next-btn,.test-container .navigation .nav-btn.submit-btn{background:linear-gradient(135deg,#ff6b9d,#ff8e8e);box-shadow:0 8rpx 24rpx rgba(255,107,157,.3);color:#fff}.test-container .navigation .nav-btn.disabled,.test-container .navigation .nav-btn[disabled]{opacity:.4}.test-container .navigation .nav-btn:active:not([disabled]){transform:scale(.97)}.test-container .navigation .nav-btn.full-width{flex:1}