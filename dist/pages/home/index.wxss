.home-container{align-items:center;background:linear-gradient(160deg,#ffe5ec,#fff0d6 50%,#e5f3ff);box-sizing:border-box;display:flex;flex-direction:column;justify-content:space-between;min-height:100vh;overflow:hidden;padding:120rpx 48rpx 80rpx;position:relative}.home-container::before{background:#ffd93d;border-radius:50%;content:"";height:220rpx;opacity:.4;position:absolute;right:-60rpx;top:-60rpx;width:220rpx}.home-container::after{background:#6bcb77;border-radius:50%;bottom:120rpx;content:"";height:160rpx;left:-40rpx;opacity:.3;position:absolute;width:160rpx}.home-container .content{align-items:center;display:flex;flex:1;flex-direction:column;justify-content:center;position:relative;z-index:1}.home-container .content .title-wrapper{align-items:center;display:flex;flex-direction:column;margin-bottom:56rpx}.home-container .content .title-wrapper .main-title{color:#ff6b9d;font-size:96rpx;font-weight:800;letter-spacing:6rpx;line-height:1;text-shadow:0 6rpx 24rpx rgba(255,107,157,.3)}.home-container .content .title-wrapper .sub-title{color:#4d96ff;font-size:44rpx;font-weight:600;letter-spacing:14rpx;margin-top:12rpx}.home-container .content .description{color:#5a4a4a;font-size:38rpx;line-height:1.7;margin-bottom:56rpx;padding:0 16rpx;text-align:center}.home-container .content .test-info{align-items:center;display:flex;flex-direction:column;gap:16rpx}.home-container .content .test-info .info-text{backdrop-filter:blur(8rpx);background:hsla(0,0%,100%,.7);border:2rpx solid rgba(255,107,157,.2);border-radius:50rpx;color:#7a5a6a;font-size:30rpx;padding:14rpx 40rpx}.home-container .footer{padding:0 24rpx;position:relative;width:100%;z-index:1}.home-container .footer .start-btn{background:linear-gradient(135deg,#ff6b9d,#ff8e8e);border:none;border-radius:54rpx;box-shadow:0 12rpx 36rpx rgba(255,107,157,.4);color:#fff;font-size:40rpx;font-weight:700;height:108rpx;letter-spacing:4rpx;line-height:108rpx;width:100%}.home-container .footer .start-btn::after{border:none}.home-container .footer .start-btn:active{box-shadow:0 8rpx 24rpx rgba(255,107,157,.3);transform:scale(.97)}