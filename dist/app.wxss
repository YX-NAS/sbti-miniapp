page{background:linear-gradient(180deg,#fff5f8,#f0f8ff);color:#3a3a3a;font-family:-apple-system,BlinkMacSystemFont,Helvetica Neue,Helvetica,Arial,PingFang SC,Hiragino Sans GB,Microsoft YaHei,sans-serif;font-size:32rpx;min-height:100vh}.card-base{background:#fff;border:2rpx solid rgba(255,107,157,.12);border-radius:32rpx;box-shadow:0 8rpx 24rpx rgba(255,107,157,.06)}.btn-gradient{background:linear-gradient(135deg,#ff6b9d,#ff8e8e);border:none;border-radius:48rpx;box-shadow:0 8rpx 24rpx rgba(255,107,157,.3);color:#fff}.text-primary{color:#ff6b9d}.text-secondary{color:#4d96ff}.text-accent{color:#6bcb77}.text-warning{color:#ffd93d}